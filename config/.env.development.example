NODE_ENV="development"

# Ключи для провайдера Github
AUTH_GITHUB_ID="AUTH_GITHUB_ID"
AUTH_GITHUB_SECRET="AUTH_GITHUB_SECRET"

# Внимание на http, используется НЕзащищенное соединение с портом
NEXTAUTH_URL="http://localhost:3000"

# Ключи для подключения к БД
POSTGRES_USER="POSTGRES_USER"
POSTGRES_PASSWORD="POSTGRES_PASSWORD"
POSTGRES_DB="POSTGRES_DB"

# --- ВНУТРЕННИЕ (IN) — для контейнеров в сети Docker ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- НАРУЖНЫЕ (OUT) — для подключения с ХОСТА (pgAdmin/psql) ---
POSTGRES_HOST_OUT=127.0.0.1
POSTGRES_HOST_PORT=6543
