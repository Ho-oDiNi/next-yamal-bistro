# В проде использовать путь /home/${{USER}}/env/next-yamal-site/
NODE_ENV="production"

# Ключи для провайдера Github.
AUTH_GITHUB_ID="AUTH_GITHUB_ID"
AUTH_GITHUB_SECRET="AUTH_GITHUB_SECRET"

# Внимание на https, используется защищенное соединение
NEXTAUTH_URL="https://${APP_DOMAIN}"

# Ключи для подключения к БД
POSTGRES_USER="POSTGRES_USER"
POSTGRES_PASSWORD="POSTGRES_PASSWORD"
POSTGRES_DB="POSTGRES_DB"

# --- ВНУТРЕННИЕ (IN) — для контейнеров в сети Docker ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- НАРУЖНЫЕ (OUT) — для подключения с ХОСТА (pgAdmin/psql) ---
POSTGRES_HOST_OUT=127.0.0.1
POSTGRES_HOST_PORT=6543

# Хранилище изображений категорий (путь внутри контейнера/сервера)
CATEGORY_IMAGES_DIR="/app/storage/category-images"
